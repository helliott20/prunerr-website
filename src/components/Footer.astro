---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
const iconUrl = `${base.replace(/\/$/, '')}/icon.svg`;

const sections = [
  {
    title: 'Project',
    links: [
      { label: 'GitHub', href: 'https://github.com/helliott20/prunerr' },
      { label: 'Releases', href: 'https://github.com/helliott20/prunerr/releases' },
      { label: 'Issues', href: 'https://github.com/helliott20/prunerr/issues' },
      { label: 'License (MIT)', href: 'https://github.com/helliott20/prunerr/blob/main/LICENSE' },
    ],
  },
  {
    title: 'Docs',
    links: [
      { label: 'Installation', href: 'https://github.com/helliott20/prunerr/wiki/Installation' },
      { label: 'Configuration', href: 'https://github.com/helliott20/prunerr/wiki/Configuration' },
      { label: 'Rules engine', href: 'https://github.com/helliott20/prunerr/wiki/Rules-Engine' },
      { label: 'API reference', href: 'https://github.com/helliott20/prunerr/wiki/API-Reference' },
    ],
  },
  {
    title: 'Community',
    links: [
      { label: 'Unraid forum', href: 'https://forums.unraid.net/topic/196929-support-prunerr-media-library-cleanup-tool/' },
      { label: 'Docker Hub', href: 'https://hub.docker.com/r/helliott20/prunerr' },
      { label: 'Unraid templates', href: 'https://github.com/helliott20/unraid-templates' },
    ],
  },
];
---

<footer class="border-t border-surface-800/60 mt-10">
  <div class="container-page py-12 sm:py-16">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8">
      <div class="col-span-2 sm:col-span-1">
        <div class="flex items-center gap-2.5">
          <img src={iconUrl} alt="" width="28" height="28" />
          <span class="font-display text-lg font-bold text-surface-50">Prunerr</span>
        </div>
        <p class="mt-3 text-sm text-surface-400 leading-relaxed">
          Intelligent media library cleanup for Plex, Sonarr and Radarr.
        </p>
      </div>

      {sections.map((section) => (
        <div>
          <h3 class="font-display text-sm font-semibold text-surface-100 uppercase tracking-wider">{section.title}</h3>
          <ul class="mt-4 space-y-2.5">
            {section.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-surface-400 hover:text-accent-300 transition-colors">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-surface-800/60 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <p class="text-sm text-surface-500">© {year} Prunerr. MIT licensed. Built for the self-hosted community.</p>
      <p class="text-xs text-surface-600 font-mono">Plex, Sonarr, Radarr, Tautulli and Overseerr are trademarks of their respective owners.</p>
    </div>
  </div>
</footer>
