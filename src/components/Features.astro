---
const features = [
  {
    icon: 'rules',
    title: 'Rules engine',
    body: '28 condition fields across quality, ratings, watch history, collections and metadata. Build with templates, natural language, or a nested condition editor with live preview.',
    accent: 'accent',
  },
  {
    icon: 'queue',
    title: 'Deletion queue',
    body: 'Nothing leaves disk without a stop in the queue first. Grace periods, four deletion actions, and the ability to protect items individually or by collection.',
    accent: 'emerald',
  },
  {
    icon: 'collections',
    title: 'Collections sync',
    body: 'Pulls movie collections from Radarr. Protect entire franchises with one click, or queue them for bulk deletion when you want a clean break.',
    accent: 'violet',
  },
  {
    icon: 'watch',
    title: 'Per-user watch history',
    body: 'Tautulli or Tracearr integration tracks who watched what. Build rules around individual users — "delete if nobody but the kids has watched it in 6 months".',
    accent: 'cyan',
  },
  {
    icon: 'discord',
    title: 'Discord notifications',
    body: 'Batched embeds when items are queued, when grace periods expire, and when files are actually removed — with titles, sizes, and the rule that matched.',
    accent: 'accent',
  },
  {
    icon: 'api',
    title: 'REST API',
    body: 'Key-authenticated REST API for scripts, automation, and mobile apps like nzb360. Drive Prunerr from anywhere you can make an HTTP request.',
    accent: 'emerald',
  },
];

function iconPath(name: string): string {
  switch (name) {
    case 'rules': return 'M3 6h18M3 12h12M3 18h6';
    case 'queue': return 'M4 6h16M4 12h10M4 18h16M20 6l-3 3 3 3';
    case 'collections': return 'M3 7h18v10H3zM7 7v10M11 7v10M15 7v10M19 7v10';
    case 'watch': return 'M12 8v4l3 2M12 22a10 10 0 1 1 0-20 10 10 0 0 1 0 20z';
    case 'discord': return 'M9 12a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm6 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2zM5 18l-2 3V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H8z';
    case 'api': return 'M16 18l6-6-6-6M8 6l-6 6 6 6';
    default: return '';
  }
}

const accentClasses: Record<string, string> = {
  accent: 'text-accent-400 bg-accent-500/10 border-accent-500/20',
  emerald: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20',
  violet: 'text-violet-400 bg-violet-500/10 border-violet-500/20',
  cyan: 'text-cyan-400 bg-cyan-500/10 border-cyan-500/20',
};
---

<section id="features" class="py-20 sm:py-28 border-t border-surface-800/60">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm uppercase tracking-[0.2em] text-accent-400 font-semibold">Features</p>
      <h2 class="mt-3 font-display text-3xl sm:text-4xl font-bold tracking-tight text-surface-50">
        Everything you need to clean up safely
      </h2>
      <p class="mt-4 text-surface-300 text-lg">
        Built for self-hosted media servers. No cloud account, no vendor lock-in, no surprises.
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map((feature) => (
        <article class="card-feature group">
          <div class={`inline-flex items-center justify-center size-11 rounded-xl border ${accentClasses[feature.accent]}`}>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={iconPath(feature.icon)} />
            </svg>
          </div>
          <h3 class="mt-5 font-display text-xl font-semibold text-surface-50">{feature.title}</h3>
          <p class="mt-2 text-surface-300 leading-relaxed">{feature.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
