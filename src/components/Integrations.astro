---
const integrations = [
  { name: 'Plex', role: 'Media server &amp; watch status', required: true },
  { name: 'Sonarr', role: 'TV show management', required: false, label: 'Recommended' },
  { name: 'Radarr', role: 'Movie management &amp; collections', required: false, label: 'Recommended' },
  { name: 'Tautulli', role: 'Per-user watch history', required: false, label: 'One required' },
  { name: 'Tracearr', role: 'Per-user watch history (alt)', required: false, label: 'One required' },
  { name: 'Overseerr', role: 'Request management', required: false, label: 'Optional' },
  { name: 'Unraid', role: 'Server monitoring', required: false, label: 'Optional' },
  { name: 'Discord', role: 'Notifications', required: false, label: 'Optional' },
];
---

<section class="py-20 sm:py-24 border-t border-surface-800/60">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm uppercase tracking-[0.2em] text-accent-400 font-semibold">Integrations</p>
      <h2 class="mt-3 font-display text-3xl sm:text-4xl font-bold tracking-tight text-surface-50">
        Plays nice with the *arr stack
      </h2>
    </div>

    <div class="mt-12 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3 max-w-5xl mx-auto">
      {integrations.map((integration) => (
        <div class="card p-5">
          <div class="flex items-center justify-between gap-2">
            <span class="font-display font-semibold text-surface-50">{integration.name}</span>
            {integration.required ? (
              <span class="text-[10px] uppercase tracking-wider font-semibold px-2 py-0.5 rounded-full bg-accent-500/15 text-accent-300 border border-accent-500/25">
                Required
              </span>
            ) : integration.label ? (
              <span class="text-[10px] uppercase tracking-wider font-medium text-surface-500">
                {integration.label}
              </span>
            ) : null}
          </div>
          <p class="mt-2 text-sm text-surface-400 leading-snug" set:html={integration.role}></p>
        </div>
      ))}
    </div>
  </div>
</section>
