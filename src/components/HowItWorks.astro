---
const steps = [
  {
    number: '01',
    title: 'Connect your services',
    body: 'Point Prunerr at your Plex, Sonarr and Radarr. Optionally Tautulli/Tracearr for per-user watch history, Overseerr for request resets, and Discord for notifications.',
  },
  {
    number: '02',
    title: 'Define a rule',
    body: 'Pick a template ("delete movies nobody watched in 6 months over 20GB") or build from scratch. Live preview shows you exactly which items would match before you save.',
  },
  {
    number: '03',
    title: 'Review the queue',
    body: 'Scheduled scans add matches to a queue. You get a Discord embed with everything that matched and what rule caught it. Protect anything you want to keep.',
  },
  {
    number: '04',
    title: 'Grace period expires',
    body: 'After your grace period, Prunerr fires the deletion through Sonarr/Radarr — file removal, unmonitor, or full removal — and resets Overseerr requests if configured.',
  },
];
---

<section id="how-it-works" class="py-20 sm:py-28 border-t border-surface-800/60">
  <div class="container-page">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-sm uppercase tracking-[0.2em] text-accent-400 font-semibold">How it works</p>
      <h2 class="mt-3 font-display text-3xl sm:text-4xl font-bold tracking-tight text-surface-50">
        Nothing gets deleted without your say-so
      </h2>
    </div>

    <ol class="mt-16 grid grid-cols-1 md:grid-cols-2 gap-5 max-w-5xl mx-auto">
      {steps.map((step) => (
        <li class="card p-6 sm:p-7 relative">
          <span class="font-mono text-sm font-medium text-accent-400/80">{step.number}</span>
          <h3 class="mt-3 font-display text-xl font-semibold text-surface-50">{step.title}</h3>
          <p class="mt-2 text-surface-300 leading-relaxed">{step.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>
